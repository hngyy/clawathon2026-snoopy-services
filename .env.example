# ── .env holds only core app config. Integration secrets live in per-service
#    credential files (see below) — copy each *.credentials.json.example and fill it in.
#    Env vars still override the files if set, so deployment can inject secrets.

# LLM provider config (any OpenAI-compatible provider)
# For GreenNode AIP: use /agentbase-llm to get an API key and set
#   LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Path to the bot config file (defaults to config.yaml)
CONFIG_PATH=config.yaml

# Memory — set both to enable AgentBase short-term + long-term memory
# MEMORY_ID=
# MEMORY_STRATEGY_ID=
# Max tokens of conversation history sent to the LLM per turn (older turns are
# trimmed from the prompt, not deleted from storage). Default 8000.
# HISTORY_TOKEN_BUDGET=8000

# ── Credentials (NOT here — use the JSON files) ──────────────────────────────
#   GreenNode IAM   → .greennode.json            (SDK-managed: client_id, client_secret)
#   Outlook / Graph → o365.credentials.json      ({tenant_id, client_id}); then run
#                       `python -m app.infrastructure.mailer login`
#   Trello (BIE)    → trello.credentials.json    ({api_key, token})
#   Google          → google.credentials.json    ({service_account, sheet_id, calendar_id})
#   Zalo Bot        → zalo.credentials.json       ({bot_token, webhook_secret, owner_password});
#                       bot_token enables /zalo/webhook; owner_password enables in-chat
#                       `/owner <password>` elevation (no redeploy needed to grant owners)
# All are git/Docker-ignored via the *.credentials.json rule. Copy the .example files.
