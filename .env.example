//GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=
# LLM provider config (any OpenAI-compatible provider)
# For GreenNode AIP: use /agentbase-llm to get an API key and set
#   LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# Path to the bot config file (defaults to config.yaml)
CONFIG_PATH=config.yaml
# Memory — set both to enable AgentBase short-term + long-term memory
# MEMORY_ID=
# MEMORY_STRATEGY_ID=
